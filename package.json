{
  "name": "create-react-native-tui",
  "version": "1.2.0",
  "type": "module",
  "description": "Interactive CLI to scaffold React Native projects",
  "main": "bin/index.js",
  "bin": {
    "react-native-tui": "./bin/index.js"
  },
  "scripts": {
    "clean": "rm -rf bin/*",
    "dev": "bun src/ui/tui.tsx",
    "check": "npx tsc --noEmit",
    "build": "pnpm clean && bun scripts/build.ts",
    "prepublishOnly": "bun run build",
    "test": "jest",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "prepare": "husky",
    "publish": "npm publish --access public"
  },
  "lint-staged": {
    "*.{ts,tsx,js,jsx}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{json,md,mdx,yml,yaml}": [
      "prettier --write"
    ]
  },
  "keywords": [
    "react-native",
    "cli",
    "scaffold",
    "clean-architecture",
    "template"
  ],
  "author": "alejandro-technology",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/alejandro-technology/react-native-init-app.git"
  },
  "bugs": {
    "url": "https://github.com/alejandro-technology/react-native-init-app/issues"
  },
  "homepage": "https://rnkit.alejandrotechnology.com",
  "publishConfig": {
    "access": "public"
  },
  "engines": {
    "node": ">= 22.0.0"
  },
  "preferGlobal": true,
  "files": [
    "bin"
  ],
  "dependencies": {},
  "devDependencies": {
    "@types/bun": "^1.3.14",
    "@types/node": "^22.10.0",
    "@types/react": "^19.2.0",
    "chalk": "^5.6.2",
    "enquirer": "^2.4.1",
    "eslint": "^9",
    "eslint-config-prettier": "^10",
    "execa": "^9.6.1",
    "globals": "^15",
    "husky": "^9",
    "ink": "^6.8.0",
    "lint-staged": "^15",
    "prettier": "^3",
    "react": "^19.2.3",
    "react-devtools-core": "^7.0.1",
    "tar": "^6.2.1",
    "typescript": "^5.8.3",
    "typescript-eslint": "^8"
  }
}
